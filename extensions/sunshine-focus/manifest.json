{
  "manifest_version": 3,
  "name": "Sunshine Focus",
  "version": "1.0.0",
  "description": "__MSG_focusDesc__",
  "default_locale": "fr",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    { "resources": ["lib.js"], "matches": ["http://*/*", "https://*/*"] }
  ],
  "action": { "default_popup": "popup.html", "default_title": "Sunshine Focus" }
}
